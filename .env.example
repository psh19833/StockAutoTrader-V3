# SAT3 Environment Configuration
# 복사해서 .env 파일을 만들고 실제 값을 입력하세요.
# cp .env.example .env
#
# ⚠️  절대 이 파일에 실제 secret 값을 작성하지 마세요.
# ⚠️  .env 파일은 .gitignore에 의해 Git에 포함되지 않습니다.
# ⚠️  secret/appkey/appsecret/token/account_no를 채팅/로그에 붙여넣지 마세요.

# ── KIS API 인증 (필수) ──
# 한국투자증권 Open API에서 발급받은 App Key
KIS_APP_KEY=
# 한국투자증권 Open API에서 발급받은 App Secret
KIS_APP_SECRET=
# KIS API 실전 서버 URL (변경하지 마세요)
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# ── 계좌 정보 ──
# 실제 매매에 사용할 계좌번호 (예: 12345678-01)
KIS_ACCOUNT_NO=
# 계좌 상품 코드 (기본값 01)
KIS_ACCOUNT_PRODUCT_CODE=01

# ── WebSocket (실시간 시세) ──
KIS_WEBSOCKET_URL=

# ── Live Trading ──
# ⚠️  반드시 false로 유지하세요. true 변경은 마지막 단계입니다.
LIVE_TRADING_ENABLED=false

# ── DB ──
# SQLite 파일 경로 (기본값: 프로젝트 루트의 sat3.db)
SAT3_DB_PATH=sat3.db
